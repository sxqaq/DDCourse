{
  "name": "ddcourse",
  "version": "1.1.0",
  "description": "一个轻量、私密、会记住学习进度的本地课程视频播放器。",
  "author": "DDCourse Contributors",
  "private": true,
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "test": "node --test tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "desktop:bundle": "vite build --config desktop/vite.config.ts"
    ,"desktop:preview": "npm run desktop:bundle && electron ."
    ,"desktop:build": "npm run desktop:bundle && electron-builder --win nsis"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "build": {
    "appId": "com.ddcourse.player",
    "productName": "DDCourse",
    "artifactName": "DDCourse-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop-dist/**/*",
      "electron/**/*",
      "public/icons/icon-192.png",
      "public/icons/icon-512.png",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": ["nsis"],
      "icon": "public/icons/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "DDCourse",
      "installerLanguages": ["zh_CN", "en_US"],
      "language": "2052"
    }
  },
  "type": "module"
}
